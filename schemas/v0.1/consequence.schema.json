{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarvia.eu/schemas/v0.1/consequence.schema.json",
  "title": "Clarvia Consequence",
  "description": "A legal, administrative, financial, or practical effect triggered by a life event. The core unit of the consequence graph.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^consequence\\.[a-z0-9_]+\\.[a-z0-9_]+\\.[a-z0-9_]+\\.[a-z0-9_]+$",
      "description": "ID grammar: consequence.<jurisdiction>.<life_event>.<domain>.<slug>"
    },
    "schema_version": { "$ref": "defs/temporal.schema.json#/$defs/schema_version" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "consequence_type": {
      "type": "string",
      "enum": ["administrative_step", "right_or_benefit", "obligation", "routing_decision", "escalation"]
    },
    "jurisdiction": { "type": "string" },
    "jurisdiction_uri": { "type": ["string", "null"], "format": "uri" },
    "life_event": { "type": "string" },
    "domain": { "type": "string" },
    "trigger": {
      "type": "object",
      "properties": {
        "condition_refs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "task_template_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_assertion_refs": { "type": "array", "items": { "type": "string" } },
    "legal_basis_refs": {
      "type": "array",
      "items": { "$ref": "defs/provenance.schema.json#/$defs/legal_basis_ref" }
    },
    "standards_export": {
      "type": ["object", "null"],
      "properties": {
        "cccev_requirement": {
          "type": ["object", "null"],
          "properties": {
            "enabled": { "type": "boolean" },
            "requirement_type": { "type": ["string", "null"] }
          }
        },
        "cpsv_public_service": {
          "type": ["object", "null"],
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "authoring_status": { "$ref": "defs/status.schema.json#/$defs/authoring_status" },
    "distribution_status": { "$ref": "defs/status.schema.json#/$defs/distribution_status" },
    "monitoring_status": { "$ref": "defs/status.schema.json#/$defs/monitoring_status" },
    "confidence": { "$ref": "defs/status.schema.json#/$defs/confidence" },
    "legal_effective_from": { "type": ["string", "null"], "format": "date" },
    "legal_effective_to": { "type": ["string", "null"], "format": "date" },
    "record_valid_from": { "type": "string", "format": "date" },
    "record_valid_to": { "type": ["string", "null"], "format": "date" },
    "provenance": { "$ref": "defs/provenance.schema.json#/$defs/provenance" }
  },
  "required": ["id", "schema_version", "title", "consequence_type", "jurisdiction", "life_event", "domain", "authoring_status", "distribution_status", "record_valid_from"]
}
