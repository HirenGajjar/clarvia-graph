{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarvia.eu/schemas/v0.1/task_template.schema.json",
  "title": "Clarvia Task Template",
  "description": "A reusable human-action template linked from consequences and instantiated as checklist items.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^task_template\\.[a-z0-9_]+\\.[a-z0-9_]+\\.[a-z0-9_]+\\.[a-z0-9_]+$",
      "description": "ID grammar: task_template.<jurisdiction>.<life_event>.<domain>.<slug>"
    },
    "schema_version": { "$ref": "defs/temporal.schema.json#/$defs/schema_version" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "action_type": { "type": "string" },
    "jurisdiction": { "type": "string" },
    "jurisdiction_uri": { "type": ["string", "null"], "format": "uri" },
    "life_event": { "type": "string" },
    "domain": { "type": "string" },
    "target": {
      "type": ["object", "null"],
      "properties": {
        "object_type": { "type": "string" },
        "object_ref": { "type": ["string", "null"] },
        "subject_role": { "type": ["string", "null"] },
        "primary_authority_ref": { "type": ["string", "null"] }
      }
    },
    "authority_refs": { "type": "array", "items": { "type": "string" } },
    "form_refs": { "type": "array", "items": { "type": "string" } },
    "deadline_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_requirements": {
      "type": ["object", "null"],
      "properties": {
        "satisfy_if": {
          "type": "string",
          "enum": ["any_set_satisfied", "all_sets_satisfied"]
        },
        "sets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "operator": { "type": "string", "enum": ["all", "any"] },
              "evidence_type_refs": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["id", "operator", "evidence_type_refs"]
          }
        }
      }
    },
    "source_assertion_refs": { "type": "array", "items": { "type": "string" } },
    "legal_basis_refs": {
      "type": "array",
      "items": { "$ref": "defs/provenance.schema.json#/$defs/legal_basis_ref" }
    },
    "rendering": {
      "type": ["object", "null"],
      "properties": {
        "checklist_group": { "type": "string" },
        "urgency_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "dependency_rank": { "type": ["integer", "null"] },
        "user_visible_caveat": { "type": ["string", "null"] }
      }
    },
    "dedupe": {
      "type": ["object", "null"],
      "properties": {
        "default_strategy": { "type": "string", "enum": ["do_not_merge_across_jurisdictions", "merge"] },
        "dedupe_key_template": { "type": "string" }
      }
    },
    "authoring_status": { "$ref": "defs/status.schema.json#/$defs/authoring_status" },
    "distribution_status": { "$ref": "defs/status.schema.json#/$defs/distribution_status" },
    "record_valid_from": { "type": "string", "format": "date" },
    "record_valid_to": { "type": ["string", "null"], "format": "date" },
    "provenance": { "$ref": "defs/provenance.schema.json#/$defs/provenance" }
  },
  "required": ["id", "schema_version", "title", "action_type", "jurisdiction", "life_event", "domain", "authoring_status", "distribution_status", "record_valid_from"]
}
