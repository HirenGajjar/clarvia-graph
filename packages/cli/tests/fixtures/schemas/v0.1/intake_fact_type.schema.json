{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clarvia.eu/schemas/v0.1/intake_fact_type.schema.json",
  "title": "Clarvia Intake Fact Type",
  "description": "A typed fact collected from the user for routing consequences.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^intake_fact\\.[a-z0-9_]+\\.[a-z0-9_]+\\.",
      "description": "ID grammar: intake_fact.<scope>.<life_event>.<path_slug>"
    },
    "schema_version": { "$ref": "defs/temporal.schema.json#/$defs/schema_version" },
    "path": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "value_type": {
      "type": "string",
      "enum": ["jurisdiction_code", "date", "boolean", "string", "enum", "multi_enum", "integer"]
    },
    "allowed_values_ref": { "type": ["string", "null"] },
    "cardinality": {
      "type": "string",
      "enum": ["single", "multiple"]
    },
    "required_for": {
      "type": "array",
      "items": { "type": "string" }
    },
    "used_by_condition_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["id", "schema_version", "path", "label", "value_type", "cardinality"]
}
