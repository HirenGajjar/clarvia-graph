{
  "name": "@clarvia/cli",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "Clarvia Graph validation and build CLI",
  "license": "EUPL-1.2",
  "type": "module",
  "bin": {
    "clarvia": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
